# Deepgram
KOTOLEAF_DEEPGRAM_API_KEY=
KOTOLEAF_DEEPGRAM_MODEL=nova-3
KOTOLEAF_DEEPGRAM_LANGUAGE=multi

# Claude (uses `claude` CLI for auth — no API key needed)
KOTOLEAF_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Google OAuth
KOTOLEAF_GOOGLE_CLIENT_ID=
KOTOLEAF_GOOGLE_CLIENT_SECRET=
KOTOLEAF_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
KOTOLEAF_ALLOWED_DOMAIN=

# JWT
KOTOLEAF_JWT_SECRET=dev-secret-change-me

# GCP / Firestore
KOTOLEAF_GCP_PROJECT_ID=kotoleaf-dev
FIRESTORE_EMULATOR_HOST=localhost:8080

# CORS
KOTOLEAF_CORS_ORIGINS=["http://localhost:5173"]

# App
KOTOLEAF_ENVIRONMENT=development
